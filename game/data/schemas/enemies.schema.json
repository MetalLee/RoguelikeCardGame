{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "res://data/schemas/enemies.schema.json",
  "title": "RoguelikeCardGame Enemies",
  "type": "object",
  "required": ["content_version", "items"],
  "additionalProperties": false,
  "properties": {
    "content_version": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "max_hp", "intent_sequence", "status_immunities", "tags", "art_key", "ui_name_key"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "max_hp": { "type": "integer", "minimum": 1 },
          "intent_sequence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "intent_type", "ui_text_key", "effects"],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string" },
                "intent_type": { "type": "string", "enum": ["attack", "defend", "buff", "debuff", "mixed"] },
                "ui_text_key": { "type": "string" },
                "effects": { "type": "array", "items": { "type": "object" } }
              }
            }
          },
          "status_immunities": { "type": "array", "items": { "type": "string" } },
          "tags": { "type": "array", "items": { "type": "string" } },
          "art_key": { "type": "string" },
          "ui_name_key": { "type": "string" }
        }
      }
    }
  }
}
