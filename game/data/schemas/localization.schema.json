{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "res://data/schemas/localization.schema.json",
  "title": "RoguelikeCardGame Localization",
  "type": "object",
  "required": ["content_version", "locale", "entries"],
  "additionalProperties": false,
  "properties": {
    "content_version": { "type": "string" },
    "locale": { "type": "string" },
    "entries": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    }
  }
}
