{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "res://data/schemas/presentation/enemy_views.schema.json",
  "title": "RoguelikeCardGame Enemy Views",
  "type": "object",
  "required": ["schema", "content_version", "items"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "roguelike_card_game.enemy_views.v1" },
    "content_version": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name_key", "stand_asset", "intent_text_keys"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "name_key": { "type": "string" },
          "stand_asset": { "type": "string" },
          "animation_sheet": {
            "type": "object",
            "required": ["sheet_asset", "frame_width", "frame_height", "frame_count", "columns", "frame_seconds"],
            "additionalProperties": false,
            "properties": {
              "sheet_asset": { "type": "string" },
              "frame_width": { "type": "integer", "minimum": 1 },
              "frame_height": { "type": "integer", "minimum": 1 },
              "frame_count": { "type": "integer", "minimum": 1 },
              "columns": { "type": "integer", "minimum": 1 },
              "frame_seconds": { "type": "number", "exclusiveMinimum": 0 }
            }
          },
          "intent_text_keys": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    }
  }
}
