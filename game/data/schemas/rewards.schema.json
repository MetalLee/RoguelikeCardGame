{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "res://data/schemas/rewards.schema.json",
  "title": "RoguelikeCardGame Rewards",
  "type": "object",
  "required": ["content_version", "items"],
  "additionalProperties": false,
  "properties": {
    "content_version": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "pack_type", "candidate_ids", "min_pick", "max_pick", "guarantee_rule", "repeat_rule", "text_key"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "pack_type": { "type": "string", "enum": ["action", "skill", "finisher"] },
          "candidate_ids": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": { "type": "string" }
          },
          "min_pick": { "type": "integer", "minimum": 0 },
          "max_pick": { "type": "integer", "minimum": 0 },
          "guarantee_rule": { "type": "string" },
          "repeat_rule": { "type": "string", "enum": ["repeatable", "unique_until_seen"] },
          "text_key": { "type": "string" }
        }
      }
    }
  }
}
