{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "res://data/schemas/cards.schema.json",
  "title": "RoguelikeCardGame Cards",
  "type": "object",
  "required": ["content_version", "items"],
  "additionalProperties": false,
  "properties": {
    "content_version": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "cost",
          "default_chain_delta",
          "target_rule",
          "effects",
          "rarity",
          "tags",
          "text_key",
          "art_key"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "type": { "type": "string", "enum": ["action", "skill", "finisher"] },
          "cost": { "type": "integer", "minimum": 0 },
          "min_chain": { "type": ["integer", "null"], "minimum": 0 },
          "default_chain_delta": { "type": ["integer", "string"], "enum": [1, 0, "consume_all"] },
          "target_rule": { "type": "string", "enum": ["single_enemy", "all_enemies", "self", "none"] },
          "effects": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": { "type": "string" },
                "target": { "type": "string" },
                "value": { "type": "integer" },
                "threshold": { "type": "integer" },
                "effect": { "type": "object" }
              },
              "additionalProperties": true
            }
          },
          "rarity": { "type": "string", "enum": ["starter", "common", "uncommon", "rare"] },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "text_key": { "type": "string" },
          "art_key": { "type": "string" }
        }
      }
    }
  }
}
