{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "res://data/schemas/gameplay/enemies.schema.json",
  "title": "RoguelikeCardGame Gameplay Enemies",
  "type": "object",
  "required": ["schema", "content_version", "items"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "roguelike_card_game.enemies.v1" },
    "content_version": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "rank", "stats", "ai", "immunities", "tags"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^enemy\\.[a-z0-9_]+$" },
          "rank": { "type": "string", "enum": ["normal", "elite", "boss"] },
          "stats": {
            "type": "object",
            "required": ["max_hp"],
            "additionalProperties": false,
            "properties": {
              "max_hp": { "type": "integer", "minimum": 1 }
            }
          },
          "ai": {
            "type": "object",
            "required": ["type", "loop", "intents"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "fixed_sequence" },
              "loop": { "type": "boolean" },
              "intents": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["id", "preview", "effects"],
                  "additionalProperties": false,
                  "properties": {
                    "id": { "type": "string", "pattern": "^intent\\.[a-z0-9_]+$" },
                    "preview": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["kind", "amount"],
                        "additionalProperties": false,
                        "properties": {
                          "kind": { "type": "string", "enum": ["attack", "block", "buff", "debuff"] },
                          "amount": { "type": "integer", "minimum": 0 }
                        }
                      }
                    },
                    "effects": { "type": "array", "items": { "type": "object" } }
                  }
                }
              }
            }
          },
          "immunities": { "type": "array", "items": { "type": "string" } },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
