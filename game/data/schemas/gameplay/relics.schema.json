{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "res://data/schemas/gameplay/relics.schema.json",
  "title": "RoguelikeCardGame Gameplay Relics",
  "type": "object",
  "required": ["schema", "content_version", "items"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "roguelike_card_game.relics.v1" },
    "content_version": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "rarity", "trigger", "conditions", "effects", "stack_rule", "tags"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^relic\\.[a-z0-9_]+$" },
          "rarity": { "type": "string", "enum": ["common", "uncommon", "rare", "boss"] },
          "trigger": { "type": "string" },
          "conditions": { "type": "array", "items": { "type": "object" } },
          "effects": { "type": "array", "items": { "type": "object" } },
          "stack_rule": { "type": "string", "enum": ["unique", "stackable"] },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
