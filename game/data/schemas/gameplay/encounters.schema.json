{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "res://data/schemas/gameplay/encounters.schema.json",
  "title": "RoguelikeCardGame Gameplay Encounters",
  "type": "object",
  "required": ["schema", "content_version", "items"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "roguelike_card_game.encounters.v1" },
    "content_version": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "node_type", "enemies", "reward_profile", "teaching_goal_key", "difficulty_note"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^encounter\\.[a-z0-9_.]+$" },
          "node_type": { "type": "string", "enum": ["normal", "elite", "boss"] },
          "enemies": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["instance_id", "enemy_id"],
              "additionalProperties": false,
              "properties": {
                "instance_id": { "type": "string" },
                "enemy_id": { "type": "string" }
              }
            }
          },
          "reward_profile": {
            "type": "object",
            "required": ["card_pack_ids", "relic_id"],
            "additionalProperties": false,
            "properties": {
              "card_pack_ids": { "type": "array", "items": { "type": "string" } },
              "relic_id": { "type": ["string", "null"] }
            }
          },
          "teaching_goal_key": { "type": "string" },
          "difficulty_note": { "type": "string" }
        }
      }
    }
  }
}
