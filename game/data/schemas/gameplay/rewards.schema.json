{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "res://data/schemas/gameplay/rewards.schema.json",
  "title": "RoguelikeCardGame Gameplay Reward Packs",
  "type": "object",
  "required": ["schema", "content_version", "items"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "roguelike_card_game.reward_packs.v1" },
    "content_version": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "pack_type", "candidate_ids", "pick", "guarantee_rule", "repeat_rule", "tags"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^reward_pack\\.[a-z0-9_.]+$" },
          "pack_type": { "type": "string", "enum": ["action", "skill", "finisher"] },
          "candidate_ids": { "type": "array", "minItems": 3, "maxItems": 3, "items": { "type": "string" } },
          "pick": {
            "type": "object",
            "required": ["min", "max"],
            "additionalProperties": false,
            "properties": {
              "min": { "type": "integer", "minimum": 0 },
              "max": { "type": "integer", "minimum": 0 }
            }
          },
          "guarantee_rule": { "type": "string" },
          "repeat_rule": { "type": "string", "enum": ["repeatable", "unique_until_seen"] },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
