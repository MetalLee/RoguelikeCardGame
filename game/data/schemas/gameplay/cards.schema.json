{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "res://data/schemas/gameplay/cards.schema.json",
  "title": "Sword Black Tower MVP Cards",
  "type": "object",
  "required": ["schema", "content_version", "items"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "sword_black_tower.cards.v1" },
    "content_version": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "weapon_id", "card_type", "rarity", "costs", "requirements", "targeting", "energy", "effects", "color_interactions", "after_play", "tags", "balance"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^card\\.[a-z0-9_]+$" },
          "weapon_id": { "type": "string", "pattern": "^weapon\\.[a-z0-9_]+$" },
          "card_type": { "type": "string", "enum": ["action", "finisher"] },
          "card_source": { "type": "string", "enum": ["weapon", "enemy", "special"] },
          "beat_actions": { "type": "array", "items": { "$ref": "#/$defs/beat_action" } },
          "finisher_attack_type": { "type": "string", "enum": ["slash", "strike", "projectile"] },
          "rarity": { "type": "string", "enum": ["starter", "common", "uncommon", "rare"] },
          "costs": { "type": "array", "items": { "$ref": "#/$defs/resource_amount" } },
          "requirements": { "type": "array", "items": { "type": "object" } },
          "targeting": {
            "type": "object",
            "required": ["mode", "side", "required"],
            "additionalProperties": false,
            "properties": {
              "mode": { "type": "string", "enum": ["single", "all", "self", "none", "random"] },
              "side": { "type": "string", "enum": ["enemy", "player", "none"] },
              "required": { "type": "boolean" }
            }
          },
          "energy": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "generate": { "$ref": "#/$defs/energy_generate" },
              "consume": { "$ref": "#/$defs/energy_consume" }
            }
          },
          "effects": { "type": "array", "items": { "type": "object" } },
          "color_interactions": {
            "type": "object",
            "required": ["enchantment", "finisher_color_effects"],
            "additionalProperties": false,
            "properties": {
              "enchantment": {
                "type": "object",
                "required": ["can_be_enchanted", "generated_energy_color"],
                "additionalProperties": false,
                "properties": {
                  "can_be_enchanted": { "type": "boolean" },
                  "generated_energy_color": { "type": "string", "enum": ["none", "inherits_enchantment"] },
                  "self_effects": { "type": "array", "items": { "type": "object" } }
                }
              },
              "finisher_color_effects": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["color_id", "effects", "stack_limit"],
                  "additionalProperties": false,
                  "properties": {
                    "color_id": { "type": "string", "pattern": "^color\\.(red|yellow|blue|green|purple)$" },
                    "effects": { "type": "array", "items": { "type": "object" } },
                    "stack_limit": { "type": "integer", "minimum": 1 }
                  }
                }
              }
            }
          },
          "after_play": { "type": "array", "items": { "type": "object" } },
          "tags": { "type": "array", "items": { "type": "string" } },
          "balance": {
            "type": "object",
            "required": ["role", "tier"],
            "additionalProperties": false,
            "properties": {
              "role": { "type": "string" },
              "tier": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "resource_amount": {
      "type": "object",
      "required": ["resource", "amount"],
      "additionalProperties": false,
      "properties": {
        "resource": { "type": "string", "enum": ["action_point"] },
        "amount": { "type": "integer", "minimum": 0 }
      }
    },
    "energy_generate": {
      "type": "object",
      "required": ["amount", "color_source"],
      "additionalProperties": false,
      "properties": {
        "amount": { "type": "integer", "minimum": 0 },
        "color_source": { "type": "string", "enum": ["none", "enchantment", "fixed_color"] },
        "fixed_color_id": { "type": "string", "pattern": "^color\\.(red|yellow|blue|green|purple)$" }
      }
    },
    "energy_consume": {
      "type": "object",
      "required": ["mode", "min_amount"],
      "additionalProperties": false,
      "properties": {
        "mode": { "type": "string", "enum": ["fixed", "x", "all"] },
        "amount": { "type": "integer", "minimum": 0 },
        "min_amount": { "type": "integer", "minimum": 0 },
        "color_filter": { "type": "string", "enum": ["any", "colored_only"] }
      }
    },
    "beat_action": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "enum": ["attack", "block", "dodge"] },
        "attack_type": { "type": "string", "enum": ["slash", "strike", "projectile"] },
        "value": { "type": "integer", "minimum": 0 },
        "repeat": { "type": "integer", "minimum": 1 },
        "dodge_chance_percent": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    }
  }
}
