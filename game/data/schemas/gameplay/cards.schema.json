{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "res://data/schemas/gameplay/cards.schema.json",
  "title": "RoguelikeCardGame Gameplay Cards",
  "type": "object",
  "required": ["schema", "content_version", "items"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "roguelike_card_game.cards.v1" },
    "content_version": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "card_type", "rarity", "costs", "requirements", "targeting", "effects", "after_play", "tags", "balance"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^card\\.[a-z0-9_]+$" },
          "card_type": { "type": "string", "enum": ["action", "skill", "finisher"] },
          "rarity": { "type": "string", "enum": ["starter", "common", "uncommon", "rare"] },
          "vfx_asset": { "type": "string", "pattern": "^asset\\.vfx\\.[a-z0-9_]+$" },
          "costs": { "type": "array", "items": { "$ref": "#/$defs/resource_amount" } },
          "requirements": { "type": "array", "items": { "type": "object" } },
          "targeting": {
            "type": "object",
            "required": ["mode", "side", "required"],
            "additionalProperties": false,
            "properties": {
              "mode": { "type": "string", "enum": ["single", "all", "self", "none"] },
              "side": { "type": "string", "enum": ["enemy", "player", "none"] },
              "required": { "type": "boolean" }
            }
          },
          "effects": { "type": "array", "items": { "type": "object" } },
          "after_play": { "type": "array", "items": { "type": "object" } },
          "tags": { "type": "array", "items": { "type": "string" } },
          "balance": {
            "type": "object",
            "required": ["role", "tier"],
            "additionalProperties": false,
            "properties": {
              "role": { "type": "string" },
              "tier": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "resource_amount": {
      "type": "object",
      "required": ["resource", "amount"],
      "additionalProperties": false,
      "properties": {
        "resource": { "type": "string", "enum": ["action_point", "chain"] },
        "amount": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
